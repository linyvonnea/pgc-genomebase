rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userUid() {
      return request.auth.uid;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function adminByEmail() {
      return isSignedIn()
        && userEmail() != null
        && exists(/databases/$(database)/documents/admins/$(userEmail()));
    }

    // Optional future collection if you decide to store admin docs by uid.
    function adminByUid() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/adminsByUid/$(userUid()));
    }

    function isAdmin() {
      return adminByEmail() || adminByUid();
    }

    // Ownership helper during migration (uid-first, email fallback).
    function ownsByUidOrEmail(uidValue, emailValue) {
      return isSignedIn() && (
        (uidValue != null && uidValue == userUid()) ||
        (emailValue != null && userEmail() != null && emailValue == userEmail())
      );
    }

    // ----- Admin and account collections -----

    match /admins/{docId} {
      allow get: if isAdmin() || (isSignedIn() && userEmail() != null && docId == userEmail());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isAdmin() || (isSignedIn() && uid == userUid());
      allow create, update: if isAdmin() || (isSignedIn() && uid == userUid());
      allow delete: if isAdmin();
    }

    match /roles/{roleId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /catalogSettings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /mail/{mailId} {
      allow read, write: if isAdmin();
    }

    match /officeCalendar/{eventId} {
      allow read: if isSignedIn();
      allow create: if isAdmin()
        && request.resource.data.createdBy == userEmail()
        && (
          !('createdByUid' in request.resource.data)
          || request.resource.data.createdByUid == userUid()
        );
      allow update, delete: if isAdmin();
    }

    // ----- Core owner-scoped collections -----

    match /inquiries/{inquiryId} {
      allow create: if isSignedIn()
        && request.resource.data.email == userEmail()
        && (
          !('ownerUid' in request.resource.data)
          || request.resource.data.ownerUid == userUid()
        )
        || (
          !isSignedIn()
          && request.resource.data.status == 'Pending'
          && request.resource.data.isApproved == false
          && request.resource.data.haveSubmitted == false
          && request.resource.data.name is string
          && request.resource.data.email is string
          && request.resource.data.affiliation is string
          && request.resource.data.designation is string
        );

      allow read: if isAdmin()
        || ownsByUidOrEmail(resource.data.ownerUid, resource.data.email);

      allow update, delete: if isAdmin()
        || (
          ownsByUidOrEmail(resource.data.ownerUid, resource.data.email)
          && request.resource.data.email == resource.data.email
          && (
            !('ownerUid' in request.resource.data)
            || request.resource.data.ownerUid == resource.data.ownerUid
            || request.resource.data.ownerUid == userUid()
          )
        );
    }

    match /clients/{cid} {
      allow create: if isAdmin()
        || (
          isSignedIn()
          && request.resource.data.email == userEmail()
          && (
            !('ownerUid' in request.resource.data)
            || request.resource.data.ownerUid == userUid()
          )
        );

      allow read: if isAdmin()
        || ownsByUidOrEmail(resource.data.ownerUid, resource.data.email);

      allow update, delete: if isAdmin()
        || (
          ownsByUidOrEmail(resource.data.ownerUid, resource.data.email)
          && request.resource.data.email == resource.data.email
          && (
            !('ownerUid' in request.resource.data)
            || request.resource.data.ownerUid == resource.data.ownerUid
            || request.resource.data.ownerUid == userUid()
          )
        );
    }

    match /clientRequests/{requestId} {
      allow create: if isSignedIn()
        && request.resource.data.requestedBy == userEmail()
        && (
          !('requestedByUid' in request.resource.data)
          || request.resource.data.requestedByUid == userUid()
        );

      allow read: if isAdmin()
        || ownsByUidOrEmail(resource.data.requestedByUid, resource.data.requestedBy);

      allow update, delete: if isAdmin()
        || (
          ownsByUidOrEmail(resource.data.requestedByUid, resource.data.requestedBy)
          && request.resource.data.requestedBy == resource.data.requestedBy
          && (
            !('requestedByUid' in request.resource.data)
            || request.resource.data.requestedByUid == resource.data.requestedByUid
            || request.resource.data.requestedByUid == userUid()
          )
        );
    }

    match /projectRequests/{requestId} {
      allow create: if isSignedIn()
        && request.resource.data.requestedBy == userEmail()
        && (
          !('requestedByUid' in request.resource.data)
          || request.resource.data.requestedByUid == userUid()
        );

      allow read: if isAdmin()
        || ownsByUidOrEmail(resource.data.requestedByUid, resource.data.requestedBy);

      allow update, delete: if isAdmin()
        || (
          ownsByUidOrEmail(resource.data.requestedByUid, resource.data.requestedBy)
          && request.resource.data.requestedBy == resource.data.requestedBy
          && (
            !('requestedByUid' in request.resource.data)
            || request.resource.data.requestedByUid == resource.data.requestedByUid
            || request.resource.data.requestedByUid == userUid()
          )
        );
    }

    match /memberApprovals/{approvalId} {
      allow create: if isSignedIn()
        && request.resource.data.submittedBy == userEmail()
        && (
          !('submittedByUid' in request.resource.data)
          || request.resource.data.submittedByUid == userUid()
        );

      allow read: if isAdmin()
        || ownsByUidOrEmail(resource.data.submittedByUid, resource.data.submittedBy);

      allow update, delete: if isAdmin()
        || (
          ownsByUidOrEmail(resource.data.submittedByUid, resource.data.submittedBy)
          && request.resource.data.submittedBy == resource.data.submittedBy
          && (
            !('submittedByUid' in request.resource.data)
            || request.resource.data.submittedByUid == resource.data.submittedByUid
            || request.resource.data.submittedByUid == userUid()
          )
        );
    }

    match /quotationThreads/{threadId} {
      allow create: if isSignedIn()
        && (
          isAdmin()
          || (
            request.resource.data.clientEmail == userEmail()
            && (
              !('clientUid' in request.resource.data)
              || request.resource.data.clientUid == userUid()
            )
          )
        );

      allow read: if isAdmin()
        || ownsByUidOrEmail(resource.data.clientUid, resource.data.clientEmail);

      allow update, delete: if isAdmin()
        || (
          ownsByUidOrEmail(resource.data.clientUid, resource.data.clientEmail)
          && request.resource.data.clientEmail == resource.data.clientEmail
          && (
            !('clientUid' in request.resource.data)
            || request.resource.data.clientUid == resource.data.clientUid
            || request.resource.data.clientUid == userUid()
          )
        );
    }

    match /threadMessages/{messageId} {
      allow create: if isSignedIn()
        && (
          (
            request.resource.data.senderId == userEmail()
            && (
              !('senderUid' in request.resource.data)
              || request.resource.data.senderUid == userUid()
            )
          )
          || (
            'senderUid' in request.resource.data
            && request.resource.data.senderUid == userUid()
          )
          || isAdmin()
        );

      allow read: if isAdmin()
        || (
          exists(/databases/$(database)/documents/quotationThreads/$(resource.data.threadId))
          && ownsByUidOrEmail(
            get(/databases/$(database)/documents/quotationThreads/$(resource.data.threadId)).data.clientUid,
            get(/databases/$(database)/documents/quotationThreads/$(resource.data.threadId)).data.clientEmail
          )
        );

      allow update, delete: if isAdmin()
        || ownsByUidOrEmail(resource.data.senderUid, resource.data.senderId);
    }

    match /quotations/{quotationId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /officialReceipts/{receiptId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.uploadedBy == userEmail();
        allow update, delete: if isAdmin()
          || resource.data.uploadedBy == userEmail();
      }

      match /serviceReports/{reportId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    match /sampleForms/{formId} {
      allow create: if isSignedIn()
        && request.resource.data.submittedByEmail == userEmail()
        && (
          !('submittedByUid' in request.resource.data)
          || request.resource.data.submittedByUid == userUid()
        );

      allow read: if isAdmin()
        || ownsByUidOrEmail(resource.data.submittedByUid, resource.data.submittedByEmail);

      allow update, delete: if isAdmin()
        || (
          ownsByUidOrEmail(resource.data.submittedByUid, resource.data.submittedByEmail)
          && request.resource.data.submittedByEmail == resource.data.submittedByEmail
          && (
            !('submittedByUid' in request.resource.data)
            || request.resource.data.submittedByUid == resource.data.submittedByUid
            || request.resource.data.submittedByUid == userUid()
          )
        );
    }

    match /sampleFormsPDF/{formId} {
      allow read: if isAdmin()
        || (
          exists(/databases/$(database)/documents/sampleForms/$(formId))
          && ownsByUidOrEmail(
            get(/databases/$(database)/documents/sampleForms/$(formId)).data.submittedByUid,
            get(/databases/$(database)/documents/sampleForms/$(formId)).data.submittedByEmail
          )
        );

      allow create, update, delete: if isAdmin()
        || (
          exists(/databases/$(database)/documents/sampleForms/$(formId))
          && ownsByUidOrEmail(
            get(/databases/$(database)/documents/sampleForms/$(formId)).data.submittedByUid,
            get(/databases/$(database)/documents/sampleForms/$(formId)).data.submittedByEmail
          )
        );
    }

    match /clientFormSubmissions/{submissionId} {
      allow create: if isSignedIn()
        && request.resource.data.uploadedBy == userEmail()
        && (
          !('uploadedByUid' in request.resource.data)
          || request.resource.data.uploadedByUid == userUid()
        );

      allow read: if isAdmin()
        || ownsByUidOrEmail(resource.data.uploadedByUid, resource.data.uploadedBy);

      allow update, delete: if isAdmin()
        || ownsByUidOrEmail(resource.data.uploadedByUid, resource.data.uploadedBy);
    }

    match /clientNotifications/{notificationId} {
      allow create: if isAdmin();

      allow read: if isAdmin()
        || ownsByUidOrEmail(resource.data.recipientUid, resource.data.recipientEmail);

      allow update, delete: if isAdmin()
        || ownsByUidOrEmail(resource.data.recipientUid, resource.data.recipientEmail);
    }

    match /chargeSlips/{chargeSlipId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /receipts/{receiptId} {
      allow create: if isSignedIn()
        && request.resource.data.uploadedBy == userEmail();

      allow read: if isSignedIn();

      allow update, delete: if isAdmin()
        || resource.data.uploadedBy == userEmail();
    }

    match /adminChannels/{channelId} {
      allow read, write: if isAdmin();
    }

    match /adminMessages/{messageId} {
      allow read, write: if isAdmin();
    }

    match /presence/{presenceId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /clientConformes/{conformeId} {
      allow create: if isSignedIn()
        && request.resource.data.data.createdBy == userEmail()
        && (
          !('createdByUid' in request.resource.data.data)
          || request.resource.data.data.createdByUid == userUid()
        );

      allow read: if isAdmin()
        || ownsByUidOrEmail(resource.data.data.createdByUid, resource.data.data.createdBy);

      allow update: if isAdmin();
      allow delete: if false;
    }

    // ----- Default deny -----

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
